{
  "name": "ayecode/wp-font-awesome-settings",
  "version": "2.0.0",
  "type": "library",
  "description": "Settings page for Font Awesome in WordPress",
  "keywords": ["font-awesome","fontawesome"],
  "homepage": "https://github.com/AyeCode/wp-font-awesome-settings",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "AyeCode Ltd",
      "email": "contact@ayecode.io",
      "homepage": "https://ayecode.io/",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=7.4.0",
    "composer/installers": "~1.0",
    "enshrined/svg-sanitize": "^0.22"
  },
  "autoload": {
    "psr-4": {
      "AyeCode\\FontAwesome\\": "src/"
    },
    "files": [
      "src/functions.php"
    ]
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
